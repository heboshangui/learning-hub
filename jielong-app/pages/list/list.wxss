page { background: #f0f4f8; font-family: 'PingFang SC', sans-serif; }
.container { padding: 24rpx; }
.empty { text-align: center; color: #bbb; padding: 100rpx 0; font-size: 28rpx; }
.form-card { background: white; border-radius: 20rpx; padding: 28rpx; margin-bottom: 20rpx; }
.form-info { flex: 1; }
.form-title { font-size: 32rpx; font-weight: 600; color: #1a1a1a; display: block; margin-bottom: 8rpx; }
.form-meta { font-size: 24rpx; color: #888; display: block; }
.form-stat { font-size: 26rpx; color: #07c160; font-weight: 600; display: block; margin-top: 8rpx; }
.form-actions { display: flex; gap: 16rpx; margin-top: 16rpx; }
.form-actions button { background: #f0f4f8; color: #555; font-size: 24rpx; }
