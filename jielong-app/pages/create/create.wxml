<view class="container">
  <view class="section">
    <view class="label">表单标题</view>
    <input class="input" placeholder="如：大六班《2026暑假安全致家长一封信》" value="{{title}}" bindinput="onTitleInput" />
  </view>
  <view class="section">
    <view class="label">正文说明</view>
    <textarea class="textarea" placeholder="请如实填写以下选项并手写签名" value="{{description}}" bindinput="onDescInput" />
  </view>
  <view class="section">
    <view class="label">截止时间</view>
    <picker mode="datetime" bindchange="onDeadlineChange" value="{{deadline}}">
      <view class="picker">{{deadline || '不设置截止时间'}}</view>
    </picker>
  </view>
  <view class="section">
    <view class="label">班级总人数</view>
    <input class="input" type="number" value="{{totalCount}}" bindinput="onCountChange" />
  </view>
  <view class="section">
    <view class="label">表单字段（默认）</view>
    <view class="field-list">
      <view wx:for="{{fields}}" wx:key="name" class="field-item">
        <text>{{item.name}}</text>
        <text wx:if="{{item.required}}" class="required">*</text>
      </view>
    </view>
  </view>
  <button class="btn-submit" bindtap="submit">创建表单</button>
</view>
