page { background: #f0f4f8; font-family: 'PingFang SC', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
.container { text-align: center; padding: 60rpx 40rpx; }
.success-icon {
  width: 140rpx; height: 140rpx; background: #07c160; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 40rpx; font-size: 72rpx; color: white; font-weight: 700;
}
.title { font-size: 44rpx; font-weight: 700; color: #1a1a1a; margin-bottom: 16rpx; }
.subtitle { font-size: 28rpx; color: #888; margin-bottom: 32rpx; }
.form-name { background: #e8f5e9; color: #07c160; padding: 16rpx 32rpx; border-radius: 12rpx; font-size: 28rpx; font-weight: 600; display: inline-block; }
